{
  "rules": {
    "donors": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.uid == $uid || root.child('donors').child(auth.uid).child('isAdmin').val() == true)"
      }
    },
    "blood_requests": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "donation_history": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
